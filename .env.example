# HYPATIA — Variables de entorno
# Copia este archivo a .env y completa los valores reales
# NUNCA subas el archivo .env al repositorio git

# NASA API Key (gratuita en https://api.nasa.gov/)
NASA_API_KEY=your_nasa_api_key_here

# Email para identificación en JPL Horizons (opcional pero recomendado)
JPL_EMAIL=your_email@universidad.edu

# Streamlit dashboard
STREAMLIT_SECRET=generate_a_random_string_here
